  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  action      String
  resource    String
  resourceId  String?
  
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}

model SessionLog {
  id          String   @id @default(cuid())
  userId      String
  
  ipAddress   String?
  userAgent   String?
  
  loginAt     DateTime @default(now())
  logoutAt    DateTime?
  
  @@index([userId])
  @@index([loginAt])
  @@map("session_logs")
}
